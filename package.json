{
  "name": "d-nd-ux-ai-seed",
  "version": "0.1.0",
  "description": "Skill-first agentic UX behavior contracts for complete UI ports.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "author": "Graziano Guiducci",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GrazianoGuiducci/d-nd-ux-ai-seed.git"
  },
  "keywords": [
    "agentic-ui",
    "ux-ai",
    "agent-skill",
    "codex-skill",
    "react",
    "workspace",
    "behavior-contracts",
    "ai-agents",
    "interface-primitives"
  ],
  "main": "./dist/d-nd-ux-ai-seed.umd.cjs",
  "module": "./dist/d-nd-ux-ai-seed.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/d-nd-ux-ai-seed.js",
      "require": "./dist/d-nd-ux-ai-seed.umd.cjs"
    },
    "./styles": "./demo/styles.css",
    "./registry": "./seed.registry.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "demo",
    "public",
    "docs",
    "skills",
    "seed.registry.json",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build:lib": "vite build --mode lib",
    "build": "npm run typecheck && npm run build:lib && npm run build:types",
    "preview": "vite preview",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "directories": {
    "doc": "docs"
  },
  "dependencies": {}
}
