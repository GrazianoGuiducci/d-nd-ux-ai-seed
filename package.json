{
  "name": "d-nd-ux-ai-seed",
  "version": "0.1.0",
  "description": "Reusable UX-AI three-column workspace seed for agentic systems.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "main": "./dist/d-nd-ux-ai-seed.umd.cjs",
  "module": "./dist/d-nd-ux-ai-seed.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/d-nd-ux-ai-seed.js",
      "require": "./dist/d-nd-ux-ai-seed.umd.cjs"
    },
    "./styles": "./demo/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "demo",
    "public",
    "docs",
    "skills",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build:lib": "vite build --mode lib",
    "build": "npm run typecheck && npm run build:lib && npm run build:types",
    "preview": "vite preview",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "csstype": "^3.2.3",
    "detect-libc": "^2.1.2",
    "fdir": "^6.5.0",
    "js-tokens": "^4.0.0",
    "lightningcss": "^1.32.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "loose-envify": "^1.4.0",
    "nanoid": "^3.3.12",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "rolldown": "^1.0.3",
    "scheduler": "^0.23.2",
    "source-map-js": "^1.2.1",
    "tinyglobby": "^0.2.17"
  },
  "keywords": [],
  "author": ""
}
